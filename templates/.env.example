# AIDLC — .env.example template
# Copiar como .env en cada proyecto y rellenar con valores reales.
# NUNCA commitear el .env con valores reales.
# Este archivo SÍ se commitea — documenta qué variables necesita el proyecto.

# ─────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────
# Environment: local | staging | production
ENVIRONMENT=local

# Nivel de logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# Puerto donde corre la aplicación
PORT=8000

# ─────────────────────────────────────────
# BASE DE DATOS
# ─────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Tamaño del pool de conexiones
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─────────────────────────────────────────
# AUTENTICACIÓN Y SEGURIDAD
# ─────────────────────────────────────────
# Clave secreta para firmar JWT — mínimo 32 caracteres, nunca reusar entre environments
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_ME_generate_with_python_secrets_token_hex_32

# Duración del access token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Duración del refresh token en días
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────
# Requests por minuto para endpoints públicos
RATE_LIMIT_PER_MINUTE=60

# Requests por minuto para endpoints de autenticación (más estricto)
RATE_LIMIT_AUTH_PER_MINUTE=5

# ─────────────────────────────────────────
# MFA
# ─────────────────────────────────────────
# Habilitar MFA: false en local, true en staging y production para roles admin
MFA_ENABLED=false

# ─────────────────────────────────────────
# SERVICIOS EXTERNOS
# ─────────────────────────────────────────
# Ejemplo: proveedor de email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=REPLACE_ME
# SMTP_PASSWORD=REPLACE_ME

# Ejemplo: servicio de storage
# STORAGE_BUCKET=REPLACE_ME
# STORAGE_REGION=us-east-1
# AWS_ACCESS_KEY_ID=REPLACE_ME
# AWS_SECRET_ACCESS_KEY=REPLACE_ME

# Ejemplo: servicio de pagos
# PAYMENT_API_KEY=REPLACE_ME
# PAYMENT_WEBHOOK_SECRET=REPLACE_ME

# ─────────────────────────────────────────
# OBSERVABILIDAD
# ─────────────────────────────────────────
# Sentry DSN para error tracking (opcional en local)
# SENTRY_DSN=REPLACE_ME

# OpenTelemetry endpoint (opcional, para tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
# Orígenes permitidos — separados por coma
# En local: http://localhost:3000,http://localhost:5173
# En production: https://app.tudominio.com
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────
# NOTAS
# ─────────────────────────────────────────
# - Todos los valores REPLACE_ME deben ser reemplazados antes de correr la app
# - En staging y production, usar el secrets manager del proveedor
# - Nunca usar los mismos valores entre environments
# - Rotar los secrets regularmente (ver NFR-S-07 en el SRD)
