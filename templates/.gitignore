# AIDLC — .gitignore template
# Copiar a la raíz del proyecto y adaptar según el stack

# ─────────────────────────────────────────
# SECRETS — NUNCA commitear
# ─────────────────────────────────────────
.env
.env.local
.env.staging
.env.production
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account.json
*-credentials.json
*-service-account.json

# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.python-version

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
pytestdebug.log

# Linting
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.pnp.*
dist/
.next/
.nuxt/
.output/
.vercel/
.netlify/

# Testing Node
coverage/
.nyc_output/
jest.config.js.bak

# ─────────────────────────────────────────
# IDEs y editores
# ─────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─────────────────────────────────────────
# Docker
# ─────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────
# Bases de datos locales
# ─────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
postgres_data/
redis_data/

# ─────────────────────────────────────────
# Logs
# ─────────────────────────────────────────
*.log
logs/
*.log.*

# ─────────────────────────────────────────
# Terraform / Infraestructura
# ─────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# ─────────────────────────────────────────
# Temporales y backups
# ─────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.backup
*.orig
